msgstr "公司名稱"

msgid "Required for companies (can be auto-filled)"
msgstr "公司戶必填（可由統編自動帶入）"

msgid "Carrier / Donation Code"
msgstr "載具 / 捐贈碼"

msgid "/ABC+123 or 3-7 digits"
msgstr "/ABC+123 或 3-7 碼捐贈碼"

msgid "City/County"
msgstr "縣市"

msgid "District"
msgstr "鄉鎮市區"

msgid "Invalid Tax ID format."
msgstr "統編格式錯誤（需為 8 碼數字）。"

msgid "Lookup failed. Please fill manually."
msgstr "查詢失敗，請手動填寫。"

msgid "No company found."
msgstr "查無此公司資料。"

